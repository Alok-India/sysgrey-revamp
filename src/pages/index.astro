---
// Sysgrey Technologies - Final Content & HD Logo (Light Theme)
const title = "Sysgrey Technologies | Bridging the Gap through Niche Skill Development";
const description = "Leading software consultancy specializing in MS Dynamics 365, Power BI, .Net Modernization, and Executive IT Staffing.";

const services = [
  { 
    id: "crm",
    name: "Dynamic CRM 365", 
    tagline: "Microsoft Excellence",
    desc: "Implementing, customizing, and integrating Dynamics CRM to fit unique business needs. We help streamline sales, marketing, and customer service processes.",
    icon: "🎯",
    features: ["Custom Implementation", "Seamless Integration", "Sales Automation"]
  },
  { 
    id: "data",
    name: "Power BI & Analytics", 
    tagline: "Insight-Driven Growth",
    desc: "Experts in creating custom Power BI reports and dashboards that provide real-time insights into your data using SSIS, SSRS, and SQL.",
    icon: "📊",
    features: ["Real-time Dashboards", "SSIS/SSRS/SQL", "Data Automation"]
  },
  { 
    id: "apps",
    name: ".Net & Power Apps", 
    tagline: "Cloud-First Development",
    desc: "Developing powerful, scalable, and secure custom .NET applications and Power Apps that automate business processes and enable better collaboration.",
    icon: "☁️",
    features: ["Custom .Net Apps", "Power Apps Automation", "Scalable Architecture"]
  },
  { 
    id: "consultancy",
    name: "Business Consultancy", 
    tagline: "Process Transformation",
    desc: "Analyzing business processes to re-invent productivity. We identify and integrate the right technologies to boost performance and gain customer insights.",
    icon: "💡",
    features: ["Operational Change", "Technical Solutions", "Productivity Gains"]
  },
  { 
    id: "staffing",
    name: "Executive Search", 
    tagline: "Bridging the Talent Gap",
    desc: "Hands-on expertise on Industrial Development allied to IT, Retail, Banking, Placement, Staffing, and Executive Search.",
    icon: "👥",
    features: ["Niche Skill Development", "IT Staffing", "Banking & Retail"]
  },
  { 
    id: "maintenance",
    name: "Software Support", 
    tagline: "Reliability Guaranteed",
    desc: "Dedicated software maintenance and troubleshooting for Dynamic CRM, SharePoint, and SQL environments to ensure business continuity.",
    icon: "🛠️",
    features: ["Troubleshooting", "SharePoint Support", "Ongoing Maintenance"]
  }
];

const leaders = [
  {
    name: "Alok Kumar",
    role: "Director",
    bio: "IIT BHU Alumnus with over 20 years of professional experience. Former CIO at QBS Learning, Senior VP at TeBS Singapore and Apar Technologies. Expertise in app modernization (AWS/Azure) and Microsoft stacks.",
    img: "https://sysgreytech.com/images/alok.jpg"
  },
  {
    name: "Anubhav Singh",
    role: "Chief Operating Officer",
    bio: "Over 19 years of experience in Talent Acquisition and Human Resource Industry. Guided several innovative companies in managing and attaining staffing programs to deliver exponential growth.",
    img: "https://sysgreytech.com/images/anubhav.jpg"
  },
  {
    name: "Alok Kumar Singh",
    role: "Project Leader",
    bio: "MS Dynamic 365 Consultant with 9+ years of experience in MS Technologies (ASP.Net, MSSQL, MVC, C#). Managed diverse projects in Education, Finance, Manufacturing, and Sales.",
    img: "https://sysgreytech.com/images/aloksingh.jpg"
  }
];

const clients = [
  { name: "Education Sector", icon: "🎓" },
  { name: "Banking & Finance", icon: "🏦" },
  { name: "Manufacturing", icon: "🏭" },
  { name: "Retail & IT", icon: "💻" },
  { name: "Healthcare", icon: "🏥" },
  { name: "Sales & CRM", icon: "📈" }
];
---

<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/sysgrey-revamp/favicon.png" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap" rel="stylesheet">
		<style>
			:root {
				--bg: #f8fafc;
				--surface: #ffffff;
				--accent: #0284c7;
				--accent-dark: #0369a1;
				--text-main: #0f172a;
				--text-dim: #475569;
				--border: #e2e8f0;
			}
			body {
				margin: 0;
				background-color: var(--bg);
				color: var(--text-main);
				font-family: 'Geist', sans-serif;
				line-height: 1.6;
			}
			.full-width { width: 100%; }
			.container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
			
			/* Header - FULL WIDTH */
			header {
				width: 100%;
				padding: 1rem 2rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
				position: sticky;
				top: 0;
				background: rgba(255, 255, 255, 0.95);
				backdrop-filter: blur(12px);
				z-index: 100;
				border-bottom: 1px solid var(--border);
				box-sizing: border-box;
			}
			.header-logo { height: 45px; width: auto; display: block; }
			nav { display: flex; gap: 2rem; }
			nav a { color: var(--text-dim); text-decoration: none; font-size: 0.875rem; font-weight: 600; transition: color 0.2s; }
			nav a:hover { color: var(--accent); }

			/* Hero Section */
			.hero { padding: 8rem 0 4rem; position: relative; overflow: hidden; }
			.hero-content { position: relative; z-index: 2; max-width: 900px; }
			.hero h1 { font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 900; line-height: 1.05; letter-spacing: -3px; margin-bottom: 2rem; color: #020617; }
			.gradient-text { background: linear-gradient(135deg, #020617 30%, var(--accent)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
			.hero p { font-size: 1.25rem; color: var(--text-dim); max-width: 650px; margin-bottom: 3rem; }

			/* Buttons */
			.btn { 
				background: var(--accent); color: #fff; padding: 0.875rem 2.25rem; border-radius: 12px; 
				text-decoration: none; font-weight: 700; display: inline-block; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
			}
			.btn:hover { background: #020617; transform: translateY(-2px); box-shadow: 0 10px 20px rgba(2, 132, 199, 0.15); }
			.btn-outline { background: transparent; border: 1.5px solid var(--border); color: var(--text-main); margin-left: 1rem; }
			.btn-outline:hover { border-color: var(--accent); background: rgba(56, 189, 248, 0.05); }

			/* Sections - REDUCED GAP */
			section { padding: 4rem 0; }
			.section-header { margin-bottom: 3rem; }
			.section-header h2 { font-size: 2.75rem; font-weight: 800; letter-spacing: -1.5px; color: #020617; margin-bottom: 1rem; }
			.section-header p { color: var(--text-dim); font-size: 1.125rem; max-width: 700px; }

			/* Services Grid */
			.services-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1.5rem; }
			.service-card { 
				background: var(--surface); padding: 3rem 2.5rem; border-radius: 24px; border: 1px solid var(--border);
				transition: all 0.4s ease; position: relative; overflow: hidden;
				box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02);
			}
			.service-card:hover { border-color: var(--accent); transform: translateY(-10px); box-shadow: 0 25px 40px -12px rgba(0, 0, 0, 0.08); }
			.service-card .icon { font-size: 2.5rem; margin-bottom: 1.5rem; display: block; }
			.service-card h3 { font-size: 1.5rem; margin-bottom: 0.75rem; color: #020617; font-weight: 800; }
			.service-card .tagline { color: var(--accent); font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 1rem; display: block; }
			.service-card p { color: var(--text-dim); font-size: 0.95rem; margin-bottom: 2rem; min-height: 4.5rem; }
			.feature-list { list-style: none; padding: 0; margin: 0; border-top: 1px solid var(--border); padding-top: 1.5rem; }
			.feature-list li { font-size: 0.875rem; color: var(--text-main); margin-bottom: 0.65rem; display: flex; align-items: center; gap: 0.5rem; font-weight: 500; }
			.feature-list li::before { content: "→"; color: var(--accent); font-weight: 900; }

			/* Leadership */
			.leaders-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2.5rem; }
			.leader-card { background: var(--surface); border-radius: 28px; border: 1px solid var(--border); overflow: hidden; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.03); }
			.leader-img { width: 100%; height: 320px; object-fit: cover; transition: 0.6s cubic-bezier(0.4, 0, 0.2, 1); }
			.leader-card:hover .leader-img { transform: scale(1.05); }
			.leader-info { padding: 2.5rem; }
			.leader-info h4 { font-size: 1.65rem; margin-bottom: 0.25rem; color: #020617; font-weight: 800; }
			.leader-info span { color: var(--accent); font-weight: 700; font-size: 0.9rem; display: block; margin-bottom: 1.5rem; text-transform: uppercase; letter-spacing: 0.5px; }
			.leader-info p { font-size: 0.9rem; color: var(--text-dim); line-height: 1.7; }

			/* Clients */
			.clients-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 2rem; }
			.client-item { 
				background: #fff; border: 1px solid var(--border); border-radius: 16px; padding: 2rem; 
				text-align: center; font-weight: 700; color: var(--text-dim); transition: all 0.3s;
			}
			.client-item:hover { transform: scale(1.05); color: var(--accent); border-color: var(--accent); }
			.client-icon { font-size: 2rem; display: block; margin-bottom: 0.5rem; }

			/* Global Presence */
			.offices { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 3rem; }
			.office { background: #fff; padding: 3rem; border-radius: 24px; border: 1px solid var(--border); }
			.office h4 { font-size: 1.35rem; margin-bottom: 1.5rem; font-weight: 800; color: #020617; border-bottom: 2px solid var(--accent); width: fit-content; padding-bottom: 0.5rem; }
			.office p { color: var(--text-dim); font-size: 1rem; white-space: pre-line; margin-bottom: 1.5rem; }
			.office a { font-weight: 700; font-size: 0.9rem; color: var(--accent); text-decoration: none; }

			/* Contact Card - Ultra Compact */
			.contact-card { background: #020617; color: #fff; padding: 2rem; border-radius: 20px; display: grid; lg:grid-cols-2 gap: 2rem; align-items: center; max-width: 900px; margin: 0 auto; }
			.contact-info h2 { font-size: 1.5rem; font-weight: 800; line-height: 1.2; margin-bottom: 0.5rem; }
			.contact-info p { color: #94a3b8; font-size: 0.9rem; margin-bottom: 1rem; }
			.form-group { margin-bottom: 0.75rem; }
			.form-group input, .form-group textarea { padding: 0.75rem; font-size: 0.875rem; }
			.submit-btn { padding: 1rem; font-size: 0.9rem; }
			.form-group label { display: block; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; margin-bottom: 0.5rem; color: #64748b; }
			.form-group input, .form-group textarea { 
				width: 100%; background: #0f172a; border: 1px solid #1e293b; border-radius: 12px; padding: 1rem; 
				color: #fff; font-family: inherit; font-size: 1rem; outline: none; transition: border-color 0.2s;
			}
			.form-group input:focus, .form-group textarea:focus { border-color: var(--accent); }
			.submit-btn { 
				width: 100%; background: var(--accent); color: #fff; padding: 1.25rem; border-radius: 12px; 
				font-weight: 800; border: none; cursor: pointer; transition: 0.2s; 
			}
			.submit-btn:hover { background: #fff; color: #020617; }

			/* Footer - FULL WIDTH SLIM */
			footer { width: 100%; padding: 1.5rem 3rem; border-top: 1px solid var(--border); background: #fff; box-sizing: border-box; }
			.footer-flex { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
			.footer-logo { height: 30px; width: auto; opacity: 0.8; }
			.copyright { color: var(--text-dim); font-size: 0.8rem; }

			@media (max-width: 768px) {
				nav { display: none; }
				header { padding: 1rem 1.5rem; }
				.hero { padding: 6rem 0 3rem; }
				.btn-outline { margin: 1rem 0 0; display: block; width: fit-content; }
				.services-grid { grid-template-columns: 1fr; }
				.contact-card { padding: 3rem 2rem; border-radius: 24px; }
				section { padding: 3rem 0; }
			}
		</style>
	</head>
	<body>
		<header>
			<img src="/sysgrey-revamp/sysgrey-logo.png" alt="Sysgrey Technologies" class="header-logo" />
			<nav>
				<a href="#solutions">Solutions</a>
				<a href="#leadership">Leadership</a>
				<a href="#clients">Clients</a>
				<a href="#global">Contact</a>
			</nav>
		</header>

		<div class="container">
			<main>
				<section class="hero">
					<div class="hero-content">
						<span style="color: var(--accent); font-weight: 800; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 1rem; display: block;">Bridging the Niche Skill Gap</span>
						<h1><span class="gradient-text">Enterprise Software</span><br/>Modernized.</h1>
						<p>Technology and business process consulting specializing in complex solution implementations that transform global businesses through Dynamics 365, SharePoint, and BI Intelligence.</p>
						<div class="actions">
							<a href="#global" class="btn">Request a Consultation</a>
							<a href="#solutions" class="btn btn-outline">Our Core Pillars</a>
						</div>
					</div>
				</section>

				<section id="solutions">
					<div class="section-header">
						<h2>Strategic Solutions</h2>
						<p>Efficient, cost-effective, and agile solutions designed to respond quickly to the dynamic nature of your business.</p>
					</div>
					<div class="services-grid">
						{services.map(s => (
							<div class="service-card shadow-sm">
								<span class="icon">{s.icon}</span>
								<span class="tagline">{s.tagline}</span>
								<h3>{s.name}</h3>
								<p>{s.desc}</p>
								<ul class="feature-list">
									{s.features.map(f => <li>{f}</li>)}
								</ul>
							</div>
						))}
					</div>
				</section>

				<section id="leadership">
					<div class="section-header">
						<h2>Executive Leadership</h2>
						<p>Highly qualified resources specializing in Microsoft ecosystem, Cloud & DevOps, AI/ML, and Full-stack development.</p>
					</div>
					<div class="leaders-grid">
						{leaders.map(l => (
							<div class="leader-card shadow-sm">
								<img src={l.img} alt={l.name} class="leader-img" />
								<div class="leader-info">
									<h4>{l.name}</h4>
									<span>{l.role}</span>
									<p>{l.bio}</p>
								</div>
							</div>
						))}
					</div>
				</section>

				<section id="clients">
					<div class="section-header text-center" style="margin-bottom: 3rem;">
						<h2 style="margin: 0 auto;">Trusted Expertise</h2>
						<p style="margin: 1rem auto;">Providing customized solutions across global industries and sectors.</p>
					</div>
					<div class="clients-grid">
						{clients.map(c => (
							<div class="client-item shadow-sm">
								<span class="client-icon">{c.icon}</span>
								{c.name}
							</div>
						))}
					</div>
				</section>

				<section id="contact">
					<div class="contact-card shadow-2xl">
						<div class="contact-info">
							<h2>Ready to build impactful software?</h2>
							<p>Let's work together to transform your business goals into digital reality. Our experts are ready to advise and guide you.</p>
							<div style="margin-top: 3rem;">
								<a href="mailto:info@sysgreytech.com" style="text-decoration: none; color: var(--accent); font-weight: 800; font-size: 1.2rem;">info@sysgreytech.com</a>
							</div>
						</div>
						<div class="contact-form">
							<form action="mailto:info@sysgreytech.com" method="post" enctype="text/plain">
								<div class="form-group">
									<label>Full Name</label>
									<input type="text" name="name" placeholder="John Doe" required />
								</div>
								<div class="form-group">
									<label>Company Email</label>
									<input type="email" name="email" placeholder="john@company.com" required />
								</div>
								<div class="form-group">
									<label>Project Details</label>
									<textarea name="message" rows="4" placeholder="How can we help?"></textarea>
								</div>
								<button type="submit" class="submit-btn">Send Message</button>
							</form>
						</div>
					</div>
				</section>

				<section id="global" style="padding-bottom: 4rem;">
					<div class="section-header">
						<h2>Global Hubs</h2>
						<p>Serving enterprise clients from our strategic centers in Singapore and India.</p>
					</div>
					<div class="offices">
						<div class="office shadow-sm">
							<h4>Singapore</h4>
							<p>1 North Bridge Road #18-03
							High Street Center
							Singapore - 179094</p>
							<a href="mailto:alok.kumar@sysgreytech.com">alok.kumar@sysgreytech.com</a>
						</div>
						<div class="office shadow-sm">
							<h4>India</h4>
							<p>Unit No 604, Artha Mart
							TechZone 4, Greater Noida West
							Uttar Pradesh - 201318</p>
							<a href="mailto:anubhav.singh@sysgreytech.com">anubhav.singh@sysgreytech.com</a>
						</div>
					</div>
				</section>
			</main>
		</div>

		<footer>
			<div class="footer-flex">
				<img src="/sysgrey-revamp/sysgrey-logo.png" alt="Sysgrey" class="footer-logo" />
				<div class="copyright">© 2026 Sysgrey Technologies. All Rights Reserved.</div>
			</div>
		</footer>
	</body>
</html>
